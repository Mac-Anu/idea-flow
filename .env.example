# ==============================================================================
# IdeaFlow Application Environment Configuration (Example Template)
# 复制本文件为 .env 并填入真实配置：cp .env.example .env
# ⚠️ SECURITY WARNING: Never commit actual credentials to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# [Infrastructure] Relational Database (PostgreSQL / Drizzle ORM)
# 核心业务数据源配置，生产环境需配置连接池参数 (PgBouncer)
# 默认值对应 docker-compose.yml 中的 postgres 服务
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://ideaflow:ideaflow@localhost:5432/ideaflow

# ------------------------------------------------------------------------------
# [Infrastructure] In-Memory Data Store (Redis)
# 承载 BullMQ 异步任务队列、会话状态以及接口级限流 (Rate Limiting)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# [Infrastructure] Full-Text Search Engine (Meilisearch)
# 提供极速全文索引支持，生产环境需强制配置 API Key 以鉴权
# MEILISEARCH_API_KEY 需与 docker-compose.yml 中的 MEILI_MASTER_KEY 保持一致
# ------------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meili_master_key

# ------------------------------------------------------------------------------
# [Security] Identity & Access Management (Better Auth)
# 负责全局 Token 签名与会话维系。生产部署时要求高熵密钥并定期轮转。
# 生成方式：openssl rand -base64 32
# ------------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace_with_a_high_entropy_random_secret
BETTER_AUTH_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# [Third-party Integrations] SMTP Notification Service
# 负责系统的 OTP 验证码分发与关键业务异步邮件触达
# ------------------------------------------------------------------------------
MAIL_CLIENT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=IdeaFlow <noreply@example.com>

# ------------------------------------------------------------------------------
# [AI Engine] Agentic Workflow & LLM Configuration (LangGraph)
# 智能体核心驱动模块，支持无缝切换任意兼容 OpenAI 规范的商业级模型基座
# ------------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_or_openai_compatible_api_key
OPENAI_BASE_URL=https://api.deepseek.com

# ------------------------------------------------------------------------------
# [Automation] n8n Webhook Authentication
# 用于接收 n8n 自动化抓取文章推送的鉴权密钥，确保不被恶意调用
# ------------------------------------------------------------------------------
N8N_SECRET_TOKEN=your_n8n_webhook_secret
